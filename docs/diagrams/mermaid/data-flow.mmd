    style MERGE fill:#bee3f8,stroke:#2b6cb0
    style TAX fill:#fefcbf,stroke:#d69e2e
    style FEAT fill:#e9d8fd,stroke:#6b46c1
    style CATALOGUE fill:#fefcbf,stroke:#d69e2e
    style EXPLORER fill:#fed7d7,stroke:#e53e3e
