flowchart LR
    INPUT["Input FASTA"] --> INGEST

    subgraph PIPELINE["Pipeline Stages"]
        direction LR
        INGEST["Ingestion<br/><i>Parse, validate,<br/>chunk</i>"]
        SCHED["Scheduler<br/><i>Generate<br/>Cartesian product</i>"]
        WORKERS["Workers ×N<br/><i>DIAMOND blastp<br/>per work package</i>"]
        MERGE["Merger<br/><i>Join, dedup,<br/>rank via DuckDB</i>"]
        TAX["Taxonomy<br/>Enrichment<br/><i>NCBI lineage<br/>join</i>"]
        FEAT["Feature<br/>Extraction<br/><i>Alignment stats +<br/>ESM-2 embeddings</i>"]

        INGEST --> SCHED
        SCHED --> WORKERS
        WORKERS --> MERGE
        MERGE --> TAX
        TAX --> FEAT
    end

    FEAT --> CATALOGUE["Data Catalogue<br/><i>DuckDB metadata,<br/>schemas, lineage</i>"]
    CATALOGUE --> EXPLORER["Results Explorer<br/><i>SQL console,<br/>feature viz,<br/>lineage viewer</i>"]

