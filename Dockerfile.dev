# Minimal dev container for running tests with DIAMOND.
# Not the production Dockerfile (Phase 4) — just enough for pytest -m integration.
#
# Usage via docker-compose:
#   docker-compose run dev pytest tests/ -v
#   docker-compose run dev pytest tests/ -m integration

FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Install DIAMOND (pinned version for reproducibility)
ARG DIAMOND_VERSION=2.1.10
RUN curl -fsSL "https://github.com/bbuchfink/diamond/releases/download/v${DIAMOND_VERSION}/diamond-linux64.tar.gz" \
    | tar -xz -C /usr/local/bin && \
    chmod +x /usr/local/bin/diamond && \
    diamond version

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app

# Copy dependency files first for layer caching
COPY pyproject.toml ./
COPY src/distributed_alignment/__init__.py src/distributed_alignment/__init__.py

# Sync dependencies (without the full source, just enough to cache the layer)
RUN uv sync --no-dev --no-install-project 2>/dev/null || true

# Copy the rest of the project
COPY . .

# Full sync with dev dependencies
RUN uv sync

# Default command
CMD ["uv", "run", "pytest", "tests/", "-v"]
