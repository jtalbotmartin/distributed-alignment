# Dev container for running tests with DIAMOND and Ray.
# Not the production Dockerfile (Phase 4) — just enough for all tests.
#
# Usage via docker-compose:
#   docker-compose run dev uv run pytest tests/ -v                  # all unit tests
#   docker-compose run dev uv run pytest tests/ -m integration -v   # integration tests
#
# Works on both x86_64 and arm64 (Apple Silicon) via conda-forge.

FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Install DIAMOND via miniforge + bioconda.
# Miniforge uses conda-forge by default (no Anaconda ToS).
# Supports both x86_64 and arm64 natively.
ARG DIAMOND_VERSION=2.1.10
RUN ARCH=$(uname -m) && \
    curl -fsSL "https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-${ARCH}.sh" \
        -o /tmp/miniforge.sh && \
    bash /tmp/miniforge.sh -b -p /opt/conda && \
    rm /tmp/miniforge.sh && \
    /opt/conda/bin/conda install -y -c conda-forge -c bioconda "diamond=${DIAMOND_VERSION}" && \
    /opt/conda/bin/conda clean -afy && \
    ln -s /opt/conda/bin/diamond /usr/local/bin/diamond && \
    diamond version

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app

# Copy dependency files first for layer caching
COPY pyproject.toml ./
COPY src/distributed_alignment/__init__.py src/distributed_alignment/__init__.py

# Sync dependencies including Ray optional extra
RUN uv sync --no-dev --no-install-project 2>/dev/null || true

# Copy the rest of the project
COPY . .

# Full sync with dev dependencies + Ray
# --extra doesn't work with package=false, so install Ray directly
RUN uv sync && uv pip install "ray[default]>=2.9"

# Default command
CMD ["uv", "run", "pytest", "tests/", "-v"]
